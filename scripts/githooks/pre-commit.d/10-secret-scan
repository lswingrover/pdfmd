#!/usr/bin/env bash
# 10-secret-scan — block commits that stage secrets, via gitleaks. AG base check.
# No-op (with a warning) when gitleaks isn't installed, so the hook stays portable
# to machines that don't have it. Canonical source: lswingrover/scotty.
set -eu
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit[secret-scan]: gitleaks not found — skipping (brew install gitleaks)" >&2
  exit 0
fi
if ! gitleaks protect --staged --redact --no-banner; then
  echo "pre-commit[secret-scan]: gitleaks flagged staged content — commit blocked." >&2
  echo "Never commit real secrets; for a false positive use a gitleaks allowlist." >&2
  exit 1
fi
exit 0
