#!/usr/bin/env bash
# 10-main-guard — block direct pushes to origin/main unless ALLOW_MAIN_PUSH=1.
# AG UNIVERSAL BASE check (byte-identical across repos; see CANONICAL.sha256).
# PR-merge flow is unaffected — only direct local HEAD:main pushes are gated.
# Reads the push ref list on stdin (fed by the pre-push dispatcher).
set -eu
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo DETACHED)
BLOCK=0
while read -r local_ref local_sha remote_ref remote_sha; do
  case $remote_ref in
    refs/heads/main) BLOCK=1 ;;
  esac
done
[ "$BLOCK" = 1 ] || exit 0
if [ "${ALLOW_MAIN_PUSH:-0}" = 1 ]; then
  echo "pre-push[main-guard]: main push ALLOWED via ALLOW_MAIN_PUSH (branch $BRANCH)" >&2
  exit 0
fi
echo >&2
echo "BLOCKED: direct push to origin/main from branch $BRANCH" >&2
echo "If intentional, re-run with: ALLOW_MAIN_PUSH=1 git push ..." >&2
echo "The guard keeps main-destined pushes deliberate (AG_DEV_POLICY §14.4)." >&2
echo >&2
exit 1
